# 飞书应用凭证（多维表同步 + 群机器人推送用）。域名固定 open.larksuite.com
# （sg.larksuite.com 账号），不是 open.feishu.cn（那个域名只服务中国大陆账号）。
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 多维表 (Bitable)：三张业务表可位于不同 Base，因此分别配置 App Token。
FEISHU_CAMPAIGN_APP_TOKEN=
FEISHU_CAMPAIGN_TABLE_ID=
FEISHU_PRODUCT_APP_TOKEN=
FEISHU_PRODUCT_TABLE_ID=
FEISHU_LISTING_APP_TOKEN=
FEISHU_LISTING_TABLE_ID=

# 日报卡片链接。三张表的 URL 默认由下面的 Base 前缀 + 对应 App Token/Table ID
# 自动生成；如租户域名不同，修改前缀即可，也可以单独配置 *_TABLE_URL 覆盖。
FEISHU_BITABLE_BASE_URL=https://zoomex.larksuite.com/base
FEISHU_CAMPAIGN_TABLE_URL=
FEISHU_PRODUCT_TABLE_URL=
FEISHU_LISTING_TABLE_URL=
DASHBOARD_PUBLIC_URL=https://joinjaye.github.io/CompAgent/

# 日报合并卡片由应用机器人发送，不使用群 webhook。以下 webhook 仅供 Phase 8
# 运维监控告警使用。
WEBHOOK_OPS=

# LLM API（Phase 4 分析层用）。src/analysis/llm.py 固定按 OpenAI 兼容协议调用
# {LLM_API_BASE}/chat/completions，LLM_API_BASE 请填不带尾部路径的 base url，
# 如 https://api.openai.com/v1 或其它 OpenAI 兼容服务商的 base url（不要带
# /chat/completions 后缀，代码会自动拼接）。
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=

# Cursor Background Agent API（cursor_sdk）凭证。只在 config/analysis.yaml 的
# llm.provider=cursor_agent 时使用，跟上面的 LLM_* 三个变量是两套互不相关的凭证
# （cursor_sdk 走 Agent.prompt()，不是 OpenAI 兼容 /chat/completions，见
# src/analysis/cursor_agent.py 顶部注释）。
CURSOR_API_KEY=
CURSOR_MODEL=auto
